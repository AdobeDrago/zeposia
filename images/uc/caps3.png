// Function to detect Safari browser
function isSafari() {
  var userAgent = window.navigator.userAgent;
  return /Safari/.test(userAgent) && !/Chrome/.test(userAgent);
}

// Check if the current page is for the "multiple-sclerosis" URL and if the browser is Safari
if (window.location.href.includes("/multiple-sclerosis") && isSafari()) {
    // Hide Onetrustformc for Safari
    var elementsToHide = document.querySelectorAll('.mssite .nav-item.cmp-utility-nav-list-item.Onetrustformc');
    elementsToHide.forEach(function(element) {
        element.style.display = 'none';
    });

    // Show Onetrustforbms for Safari
    var elementsToShow = document.querySelectorAll('.mssite .nav-item.cmp-utility-nav-list-item.Onetrustforbms');
    elementsToShow.forEach(function(element) {
        element.style.display = 'block';
    });
	// Show Onetrustforbms for Safari
    var elementsToShow = document.querySelectorAll('.mssite .nav-item.cmp-utility-nav-list-item.Onetrustforbms a.nav-link::after');
    elementsToShow.forEach(function(element) {
        element.style.setProperty('display', 'none', 'important');
    });

    // Hide the after pseudo-element of Onetrustforbms a.nav-link
    var elementsToModify = document.querySelectorAll('.mssite .nav-item.cmp-utility-nav-list-item.Onetrustformc a.nav-link');
    elementsToModify.forEach(function(element) {
        element.style.setProperty('display', 'none', 'important');
    });
}



    });
