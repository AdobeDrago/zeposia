<script>

$('document').ready(function(){
	
/* Click event to open ISI on gray bar */
$('.sticky-element .isi-header').on('click', function(event){
     var $this = $(this);
        $parentContainer = $this.closest('.cmp-isi');
        $parentContainer.find('.isi-container').hide();
        $parentContainer.find('.expand-container').show();
        $parentContainer.removeClass('is-collapsed is-preview').addClass('is-expanded');
        $isiOverlay.show();
		if (($parentContainer).find('.isi-footer-wrapper').length == 0) {
            $body.find('.isi-footer-wrapper').clone().appendTo(".cmp-isi.is-expanded .expand-container");
        }
		$body.addClass('no-scroll');
});

/* Add the target blank to footer logo link */
var anchors = document.getElementById('ftrlogocont').getElementsByTagName('a');
    i = anchors.length;

while(i--) anchors[i].target = "_blank";

	$(window).scroll(function(){
				var scroll = $(window).scrollTop();
				if (scroll >= 40) {
					$('.gatway-wrapper .top-header').addClass('fixedGMenu');
				}else{
					$('.gatway-wrapper .top-header').removeClass('fixedGMenu');
				}
		});
});


</script>
    
    

</div>

